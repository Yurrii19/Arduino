#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <Servo.h>
#include <Stepper.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);
Servo myServo;

const int stepsPerRevolution = 2048; 
Stepper myStepper(stepsPerRevolution, 9, 11, 10, 12); 

const int sensorPin = 2, servoPin = 6;
enum SystemState { READY, WATER_CONFIRM, SERVO_RELEASE, REACTION_WAIT, STEPPER_ACTIVE, CHECK_WATER, COMPLETE, SEVERE_CLOG };
SystemState currentState = READY;

unsigned long confirmStart, timerStart;
const unsigned long confirmTime = 3000, servoDuration = 3000, reactionTime = 10000, cleaningDuration = 20000, checkPause = 3000; 
int declogCycles = 0;
const int MAX_CYCLES = 3;

void stopStepper() {
  digitalWrite(9, LOW); digitalWrite(10, LOW); digitalWrite(11, LOW); digitalWrite(12, LOW);
}

void lcdMessage(const char* l1, const char* l2) {
  lcd.clear(); lcd.setCursor(0, 0); lcd.print(l1); lcd.setCursor(0, 1); lcd.print(l2);
}

bool readWaterSensor() {
  int waterCount = 0;
  for (int i = 0; i < 15; i++) { if (digitalRead(sensorPin) == HIGH) waterCount++; delay(2); }
  return (waterCount >= 12);
}

void setup() {
  pinMode(sensorPin, INPUT_PULLUP);
  pinMode(9, OUTPUT); pinMode(10, OUTPUT); pinMode(11, OUTPUT); pinMode(12, OUTPUT);
  myServo.attach(servoPin);
  myServo.write(0);
  myStepper.setSpeed(18); 
  lcd.init();
  lcd.backlight();
  lcdMessage("ClogSense System", "Monitoring...");
  stopStepper();
}

void loop() {
  bool waterPresent = readWaterSensor();
  unsigned long now = millis();

  switch (currentState) {
    case READY:
      declogCycles = 0;
      if (waterPresent) { 
        confirmStart = now; 
        currentState = WATER_CONFIRM; 
        lcdMessage("Water detected", "Confirming..."); 
      }
      break;

    case WATER_CONFIRM:
      if (!waterPresent) { currentState = READY; lcdMessage("Water gone", "Monitoring"); break; }
      if (now - confirmStart >= confirmTime) {
        stopStepper();       // Kill stepper power
        delay(100);          // Let voltage stabilize
        
        myServo.attach(servoPin); // WAKE UP SERVO
        myServo.write(180);       // MOVE
        
        declogCycles = 1; 
        timerStart = now;
        currentState = SERVO_RELEASE;
        lcdMessage("Cycle #1", "Releasing Sosa");
      }
      break;

    case SERVO_RELEASE:
      if (now - timerStart >= servoDuration) {
        myServo.write(0);    // MOVE BACK
        delay(600);          // Wait for it to physically reach 0
        myServo.detach();    // GO TO SLEEP (Stops vibration)
        
        timerStart = now;
        currentState = REACTION_WAIT;
        lcdMessage("Sosa reacting", "Please wait");
      }
      break;

    case REACTION_WAIT:
      if (now - timerStart >= reactionTime) {
        currentState = STEPPER_ACTIVE;
      }
      break;

    case STEPPER_ACTIVE:
      { // Brackets are REQUIRED here to fix the scope issue
        lcdMessage("Step 1: Spin", "20s Action...");
        unsigned long startCleaning = millis();
        while (millis() - startCleaning < cleaningDuration) {
          myStepper.step(20); // Move in chunks
        }
        stopStepper();
        timerStart = millis(); // Reset timer for the checkPause
        currentState = CHECK_WATER;
      }
      break;

    case CHECK_WATER:
      // 1. If water is finally gone, we are done
      if (!waterPresent) { 
        currentState = COMPLETE; 
        break; 
      }
      
      // 2. If water is STILL there, wait for checkPause (3s) then repeat or fail
      if (now - timerStart < checkPause) {
        // Show a countdown so you know it's not "stuck"
        lcd.setCursor(0, 0); lcd.print("Still Clogged   ");
        lcd.setCursor(0, 1); lcd.print("Retry in: ");
        lcd.print((checkPause - (now - timerStart)) / 1000);
        lcd.print("s ");
      } else {
        declogCycles++;
        if (declogCycles > MAX_CYCLES) {
          currentState = SEVERE_CLOG;
        } else {
          currentState = STEPPER_ACTIVE; // Go back to spinning
        }
      }
      break;

    case COMPLETE: 
      lcdMessage("Drain cleared!", "SUCCESS");
      stopStepper(); 
      delay(5000); 
      myServo.write(0); 
      currentState = READY; 
      break;

    case SEVERE_CLOG: 
      lcdMessage("SEVERE CLOG", "Manual Clean!");
      stopStepper(); 
      delay(10000); 
      myServo.write(0); 
      currentState = READY; 
      break;
  }
}
